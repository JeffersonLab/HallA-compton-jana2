#pragma once

// Generated by CMake — do not edit manually.
//
// Provides project-wide config file path resolution for jana2_common_extensions.
// Any plugin that needs to open a config file should use jce_config_path().
//
// Resolution order at runtime:
//   1. $JCE_CONFIG_DIR/<filename>     — user override, always wins
//   2. <install_prefix>/config/<filename> — after make install (checked if it exists)
//   3. throw an exception if the file is not found in the above two locations

#include <cstdlib>
#include <string>
#include <filesystem>

// Baked in at cmake configure time via -DCMAKE_INSTALL_PREFIX=...
static constexpr const char* JCE_INSTALL_CONFIG_DIR =
    "@CMAKE_INSTALL_PREFIX@/config/@INSTALL_NAMESPACE@";

// Resolve a config filename to a full path.
// Pass just the bare filename, e.g. "filter.db" — the subdir is baked in above.
inline std::string jce_config_path(const std::string& filename, std::string param_name) {
    // 1. Explicit user override
    const char* env = std::getenv("JCE_CONFIG_DIR");
    if (env) return std::string(env) + "/" + filename;

    // 2. Installed location — only use if the file actually exists there
    std::string install_path = std::string(JCE_INSTALL_CONFIG_DIR) + "/" + filename;
    if (std::filesystem::exists(install_path)) return install_path;

    // 3. Throw exception if the file is not found
    throw JException(
        "JCE_CONFIG_PATH: %s not found. Set -P%s=/path/to/%s, or set JCE_CONFIG_DIR "
        "to the directory containing all config files, or create the file at %s/%s.",
        filename.c_str(), param_name.c_str(), filename.c_str(), JCE_INSTALL_CONFIG_DIR, filename.c_str());
}
